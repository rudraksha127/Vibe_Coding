{
  "name": "interviewforge-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend API for InterviewForge AI.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
